# Copiá este archivo a .env.local y completá los valores.
# Los datos de Supabase están en: Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Nombre del sitio (se muestra en el header y el título de la pestaña)
NEXT_PUBLIC_SITE_NAME=Mundo JJersey

# Número de WhatsApp del negocio, con código de país, sin espacios ni signos.
# Ejemplo Argentina: 5491122334455
NEXT_PUBLIC_WHATSAPP_NUMBER=5490000000000

# URL pública del sitio ya deployado (sin barra al final). Se usa para que
# el link se vea con imagen al compartirlo por WhatsApp/redes.
# Ejemplo: https://mundojersey.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opcional: para poder elegir fotos directo desde Google Drive en el admin.
# Se crean en console.cloud.google.com (ver README, sección Google Drive).
# Si se dejan vacías, el botón de Google Drive simplemente no aparece.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_API_KEY=
NEXT_PUBLIC_GOOGLE_APP_ID=
